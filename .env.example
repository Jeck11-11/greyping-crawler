# GreyPing OSINT API — Environment Variables
# Copy to .env and edit: cp .env.example .env

# ---------------------------------------------------------------------------
# Authentication (comma-separated; leave empty to disable auth in dev mode)
# ---------------------------------------------------------------------------
OSINT_API_KEYS=

# ---------------------------------------------------------------------------
# Third-party API keys
# ---------------------------------------------------------------------------
HIBP_API_KEY=
C99_API_KEY=

# ---------------------------------------------------------------------------
# Nuclei integration (set to nuclei-api URL to enable vuln scanning)
# ---------------------------------------------------------------------------
# NUCLEI_API_URL=http://nuclei-api:8080
NUCLEI_TIMEOUT=120
CVE_LOOKUP_TIMEOUT=10

# ---------------------------------------------------------------------------
# Rate limits (requests per minute per key/IP; 0 = disabled)
# ---------------------------------------------------------------------------
RATE_LIMIT_SCAN=60
RATE_LIMIT_RECON=300

# ---------------------------------------------------------------------------
# Target validation
# ---------------------------------------------------------------------------
# Comma-separated hostnames to block (in addition to private IPs/loopback)
TARGET_DENYLIST=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Timeouts (seconds)
# ---------------------------------------------------------------------------
HTTP_TIMEOUT=15
CRAWL_TIMEOUT=30
SSL_TIMEOUT=10
PATH_SCAN_TIMEOUT=10
JS_MINE_TIMEOUT=30
PASSIVE_TIMEOUT=15
BREACH_TIMEOUT=15
DNS_LIFETIME=8

# ---------------------------------------------------------------------------
# Crawler limits
# ---------------------------------------------------------------------------
MAX_PAGES=50
MAX_SCRIPTS=50
PATH_CONCURRENCY=10
BREACH_EMAIL_CAP=10
PLAYWRIGHT_EXTRA_WAIT_MS=2000

# ---------------------------------------------------------------------------
# User-Agent strings
# ---------------------------------------------------------------------------
UA_HONEST=GreypingCrawler/1.0
# UA_BROWSER=Mozilla/5.0 (Windows NT 10.0; Win64; x64) ...
